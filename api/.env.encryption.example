# Database Encryption Configuration
# Copy this file to .env.encryption and configure for your environment

# Enable/disable database encryption
ENCRYPTION_ENABLED=true

# Encryption algorithm (currently only AES-256-GCM is supported)
ENCRYPTION_ALGORITHM=AES-256-GCM

# Key derivation iterations (higher = more secure but slower)
KEY_DERIVATION_ITERATIONS=100000

# Key vault provider: local, aws_kms, azure_kv, hashicorp_vault
KEY_VAULT_PROVIDER=local

# Master key configuration
MASTER_KEY_ID=default-master-key
MASTER_KEY_PATH=/app/keys/master.key

# Key rotation settings
KEY_ROTATION_INTERVAL_DAYS=90
KEY_ROTATION_ENABLED=true

# AWS KMS configuration (only needed if KEY_VAULT_PROVIDER=aws_kms)
AWS_KMS_KEY_ID=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Azure Key Vault configuration (only needed if KEY_VAULT_PROVIDER=azure_kv)
AZURE_KEY_VAULT_URL=
AZURE_KEY_VAULT_KEY_NAME=
AZURE_CLIENT_ID_KV=
AZURE_CLIENT_SECRET_KV=
AZURE_TENANT_ID_KV=

# HashiCorp Vault configuration (only needed if KEY_VAULT_PROVIDER=hashicorp_vault)
VAULT_URL=
VAULT_TOKEN=
VAULT_MOUNT_PATH=secret
VAULT_KEY_PATH=encryption-keys

# Encryption monitoring and alerting
ENCRYPTION_MONITORING_ENABLED=true
ENCRYPTION_ALERT_WEBHOOK_URL=
ENCRYPTION_METRICS_ENDPOINT=/metrics

# Performance tuning
ENCRYPTION_KEY_CACHE_TTL=3600
ENCRYPTION_BATCH_SIZE=1000