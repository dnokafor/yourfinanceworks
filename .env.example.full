# ------------------------------------------------------------
# Invoice App — Full Environment Example
# Copy to .env and adjust values as needed
# ------------------------------------------------------------

# ---------------------- Core API ----------------------------
SECRET_KEY=change-me-please
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
DEBUG=False
LOG_LEVEL=INFO

# ---------------------- Databases ---------------------------
# Master database (tenants metadata & super users)
DATABASE_URL=postgresql://postgres:password@postgres-master:5432/invoice_master

# Multi-tenant configuration
MULTITENANT_MODE=database_per_tenant
TENANT_DATABASE_PREFIX=tenant_
MASTER_DATABASE_HOST=postgres-master
MASTER_DATABASE_PORT=5432
MASTER_DATABASE_USER=postgres
MASTER_DATABASE_PASSWORD=password

# Optional: tenant DB URL template (used by some scripts)
TENANT_DB_URL_TEMPLATE=postgresql://postgres:password@postgres-master:5432/tenant_{tenant_id}

# ---------------------- Kafka / OCR -------------------------
# Set to kafka:9092 when using docker-compose included Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_OCR_TOPIC=expenses_ocr
KAFKA_OCR_GROUP=invoice-app-ocr

# OCR/LLM Model (Ollama)
OLLAMA_API_URL=http://localhost:11434/api/generate
OCR_MODEL=llama3.2-vision:11b
# Alternatively specify
# OLLAMA_MODEL=llama3.2-vision:11b

# ---------------------- Slack (optional) --------------------
SLACK_VERIFICATION_TOKEN=
SLACK_BOT_TOKEN=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# ---------------------- Analytics (optional) ----------------
GOOGLE_ANALYTICS_ID=
MIXPANEL_TOKEN=
ANALYTICS_WEBHOOK_URL=
ANALYTICS_API_KEY=
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com
AMPLITUDE_API_KEY=

# ---------------------- Email Providers (optional) ----------
# AWS SES
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

# Azure Email Services
AZURE_EMAIL_CONNECTION_STRING=

# Mailgun
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# ---------------------- UI ---------------------------------
# API base URL for the UI (K8s/Prod can override). In docker-compose UI uses /api/v1 via nginx.
VITE_API_URL=http://localhost:8000/api/v1

# ---------------------- Misc --------------------------------
# Feature flags, etc. (add as needed)
